# Your Flare project API key (required)
FLARE_API_KEY=

# Flare ingestion base URL
# FLARE_BASE_URL=https://ingress.flareapp.io

# Address and port the daemon listens on
# FLARE_DAEMON_LISTEN=127.0.0.1:8787

# Log verbosity: critical, error, info, verbose
# FLARE_DAEMON_LOG_LEVEL=info

# Path to composer.lock for update detection (leave empty to disable)
# FLARE_COMPOSER_LOCK=
